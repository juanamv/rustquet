SERVER_ADDR=127.0.0.1:3000
DB_PATH=rustquet_data
PARQUET_OUTPUT_DIR=parquet_output
BATCH_SIZE=10000
INGEST_CHANNEL_CAPACITY=8192
PARQUET_CHANNEL_CAPACITY=1
SCHEMA_CONFIG_PATH=config.json
# opcional: comenta esta linea para deshabilitar auth bearer
INGEST_BEARER_TOKEN=test-bearer-token

TEST_PUSH_PRIMARY_BUCKET=telemetry-primary
TEST_PUSH_PRIMARY_PREFIX=rustquet/primary
TEST_PUSH_PRIMARY_ENDPOINT=http://127.0.0.1:9000
TEST_PUSH_PRIMARY_REGION=us-east-1
TEST_PUSH_PRIMARY_ACCESS_KEY_ID=minioadmin
TEST_PUSH_PRIMARY_SECRET_ACCESS_KEY=minioadmin
TEST_PUSH_PRIMARY_ALLOW_HTTP=true

TEST_PUSH_BACKUP_BUCKET=telemetry-backup
TEST_PUSH_BACKUP_PREFIX=rustquet/backup
TEST_PUSH_BACKUP_ENDPOINT=http://127.0.0.1:9001
TEST_PUSH_BACKUP_REGION=us-east-1
TEST_PUSH_BACKUP_ACCESS_KEY_ID=minioadmin
TEST_PUSH_BACKUP_SECRET_ACCESS_KEY=minioadmin
TEST_PUSH_BACKUP_ALLOW_HTTP=true

TEST_PUSH_ARCHIVE_BUCKET=telemetry-archive
TEST_PUSH_ARCHIVE_PREFIX=rustquet/archive
TEST_PUSH_ARCHIVE_ENDPOINT=http://127.0.0.1:9002
TEST_PUSH_ARCHIVE_REGION=us-east-1
TEST_PUSH_ARCHIVE_ACCESS_KEY_ID=minioadmin
TEST_PUSH_ARCHIVE_SECRET_ACCESS_KEY=minioadmin
TEST_PUSH_ARCHIVE_ALLOW_HTTP=true
