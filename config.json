{
  "dataset": {
    "write_manifest": true
  },
  "push": [
    {
      "name": "lake_primary",
      "kind": "s3_compatible",
      "bucket": "bucket",
      "prefix": "dev/",
      "endpoint": "http://127.0.0.1:9222",
      "region": "us-east-1",
      "allow_http": true,
      "env": {
        "access_key_id": "PUSH_ACCESS_KEY_ID",
        "secret_access_key": "PUSH_SECRET_ACCESS_KEY"
      }
    }
  ],
  "schema": {
    "schema_version": 3,
    "columns": [
      {
        "name": "slot",
        "source": "metadata.slot",
        "type": "string"
      },
      {
        "name": "h2o",
        "source": "metadata.h2o",
        "type": "boolean",
        "materialized": false
      }
    ]
  }
}
